{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": false,
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
    ,"types": ["node"]
  },
  "include": ["src/**/*.ts", "legacy/**/*.ts"],
  "exclude": ["dist", "node_modules", "tests"]
}
